# --- Supabase ---
# URL du projet (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
# Clé anonyme (publique, protégée par RLS). Aucune clé service_role n'est
# nécessaire : tout le parcours applicatif repose sur les politiques RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (Claude) ---
# Alias accepté : une variable nommée `claude` fonctionne aussi.
ANTHROPIC_API_KEY=
# Modèle utilisé pour le parsing et le matching (optionnel)
ANTHROPIC_MODEL=claude-opus-4-8

# --- Phase 7 uniquement (WhatsApp Cloud API) — ne pas remplir au MVP ---
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
